---
/**
 * ArticleNav – 이전/다음 글 + 목록 링크 (블로그 글 하단)
 *
 * Usage:
 *   <ArticleNav prev={...} next={...} backHref="/blog" backText="All articles" />
 */
interface PostLink {
  slug: string;
  title: string;
}
interface Props {
  prev?: PostLink | null;
  next?: PostLink | null;
  /** 목록으로 돌아가기 링크 (있으면 가운데 표시) */
  backHref?: string;
  backText?: string;
}
const { prev = null, next = null, backHref = '', backText = '' } = Astro.props;
const base = '/blog';
const showBack = backHref && backText;
---
<nav class="article-nav" aria-label="글 네비게이션">
  {showBack && (
    <div class="article-nav-back-row">
      <a href={backHref} class="article-nav-back">
        <svg class="article-nav-back-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
          <path d="M9.70711 17.2929C10.0976 17.6834 10.0976 18.3166 9.70711 18.7071C9.31658 19.0976 8.68342 19.0976 8.29289 18.7071L2.29289 12.7071C1.90237 12.3166 1.90237 11.6834 2.29289 11.2929L8.29289 5.29289C8.68342 4.90237 9.31658 4.90237 9.70711 5.29289C10.0976 5.68342 10.0976 6.31658 9.70711 6.70711L5.41421 11L21 11C21.5523 11 22 11.4477 22 12C22 12.5523 21.5523 13 21 13L5.41422 13L9.70711 17.2929Z"/>
        </svg>
        {backText}
      </a>
    </div>
  )}
  <div class="article-nav-inner">
    {prev ? (
      <a href={`${base}/${prev.slug}`} class="article-nav-link article-nav-prev">
        <span class="article-nav-label">이전 글</span>
        <span class="article-nav-title">{prev.title}</span>
      </a>
    ) : (
      <span class="article-nav-link article-nav-empty" aria-hidden="true" />
    )}
    {next ? (
      <a href={`${base}/${next.slug}`} class="article-nav-link article-nav-next">
        <span class="article-nav-label">다음 글</span>
        <span class="article-nav-title">{next.title}</span>
      </a>
    ) : (
      <span class="article-nav-link article-nav-empty" aria-hidden="true" />
    )}
  </div>
</nav>

<style>
  .article-nav {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .article-nav-back-row {
    margin-bottom: 1.25rem;
  }
  .article-nav-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .article-nav-back:hover {
    color: var(--color-text);
  }
  .article-nav-back-icon {
    flex-shrink: 0;
  }
  .article-nav-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .article-nav-link {
    display: block;
    padding: 0.75rem 0;
    text-decoration: none;
    color: var(--color-text-secondary);
    transition: color 0.2s ease;
  }
  .article-nav-link:hover {
    color: var(--color-accent);
  }
  .article-nav-prev {
    text-align: left;
  }
  .article-nav-next {
    text-align: right;
  }
  .article-nav-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }
  .article-nav-title {
    display: block;
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.4;
  }
  .article-nav-empty {
    padding: 0;
    visibility: hidden;
  }
  @media (max-width: 640px) {
    .article-nav-inner {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .article-nav-next {
      text-align: left;
    }
  }
</style>
