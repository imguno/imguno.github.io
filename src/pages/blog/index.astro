---
/**
 * Blog index with category + tag filter.
 * Reusable FilterBar; grid id = blog-filter-grid, items have data-filterable, data-category, data-tags.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import FilterBar from '../../components/FilterBar.astro';
import { getCollection } from 'astro:content';
import { pagesConfig } from '../../pages.config';
import { sortCategories } from '../../utils/filterHelpers';
import { BLOG_CATEGORY_ORDER } from '../../utils/filterHelpers';

const allBlogArticles = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const categories = sortCategories(
  [...new Set(allBlogArticles.map((a) => a.data.category).filter(Boolean))] as string[],
  BLOG_CATEGORY_ORDER
);
const tags = [...new Set(allBlogArticles.flatMap((a) => a.data.tags ?? []))].sort();

const tagCategoryMap: Record<string, string[]> = {};
allBlogArticles.forEach((a) => {
  const cat = (a.data.category || '').trim();
  (a.data.tags ?? []).forEach((t: string) => {
    if (!tagCategoryMap[t]) tagCategoryMap[t] = [];
    if (cat && !tagCategoryMap[t].includes(cat)) tagCategoryMap[t].push(cat);
  });
});
---

<BaseLayout>
  <SEO slot="head" title={pagesConfig.blog.title} description={pagesConfig.blog.description} type="website" />

  <main class="page-container">
    <header class="page-header">
      <h1 class="page-title">{pagesConfig.blog.heading}</h1>
      <p class="page-intro">{pagesConfig.blog.intro}</p>
    </header>

    <div class="filter-bar-top" aria-label="필터">
      <FilterBar
        filterId="blog"
        categories={categories}
        tags={tags}
        categoryLabel="카테고리"
        tagLabel="태그"
        collapsible
        tagCategoryMap={tagCategoryMap}
      />
    </div>

    <div id="blog-filter-grid" class="card-list">
      {allBlogArticles.map((article) => {
        const cat = article.data.category ?? '';
        const tagsStr = (article.data.tags ?? []).join(',');
        return (
          <div data-filterable data-category={cat} data-tags={tagsStr}>
            <ArticleCard
              title={article.data.title}
              slug={article.id}
              description={article.data.description}
              publishDate={article.data.publishDate}
              tags={article.data.tags}
            />
          </div>
        );
      })}
    </div>
    <p id="blog-filter-empty" class="empty-state" style="display: none;">필터에 맞는 글이 없습니다.</p>
  </main>
</BaseLayout>
